# ============================================================================
# AWARDX SUPABASE ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and replace the placeholder values with your actual keys
# Get these from your Supabase project: https://app.supabase.com
# ============================================================================

# ======================
# SUPABASE CORE
# ======================

# Your Supabase project URL (found in Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (found in Project Settings > API)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose this in frontend - server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ======================
# AUTHENTICATION
# ======================

# Site URL for auth redirects (your app's URL)
VITE_SITE_URL=http://localhost:3000

# OAuth providers (optional - configure in Supabase Dashboard)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id
# VITE_GITHUB_CLIENT_ID=your-github-client-id

# ======================
# PAYMENT PROVIDERS
# ======================

# Stripe (optional - for payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PayPal (optional)
# VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_SECRET=your-paypal-secret

# Razorpay (optional)
# VITE_RAZORPAY_KEY_ID=your-razorpay-key
# RAZORPAY_KEY_SECRET=your-razorpay-secret

# ======================
# STORAGE
# ======================

# Supabase Storage bucket names (these should match buckets in your Supabase project)
VITE_STORAGE_BUCKET_AVATARS=avatars
VITE_STORAGE_BUCKET_SUBMISSIONS=submissions
VITE_STORAGE_BUCKET_PROGRAM_ASSETS=program-assets

# ======================
# EMAIL (Supabase handles this, but custom SMTP is optional)
# ======================

# Custom SMTP (optional - configure in Supabase Dashboard for production)
# SMTP_HOST=smtp.your-email-provider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@yourdomain.com

# ======================
# SOCIAL MEDIA INTEGRATIONS
# ======================

# Twitter/X API (for social posting feature)
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret
# TWITTER_ACCESS_TOKEN=your-access-token
# TWITTER_ACCESS_SECRET=your-access-secret

# LinkedIn API
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-secret

# ======================
# ANALYTICS (Optional)
# ======================

# Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# ======================
# AI FEATURES (from your existing config)
# ======================

# Gemini API for AI features
GEMINI_API_KEY=your-gemini-api-key

# ======================
# MISC
# ======================

# App environment
VITE_APP_ENV=development

# Enable debug logging
VITE_DEBUG=false

# API base URL (if you have a separate backend)
# VITE_API_URL=https://api.yourdomain.com
